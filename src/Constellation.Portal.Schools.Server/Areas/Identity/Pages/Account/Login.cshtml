@page
@model LoginModel

<h1>@ViewData["Title"]</h1>
<div class="row">
    <div class="col-offset-3 col-md-9">
        <section>
            <h2>Login with a DoE Account</h2>
            <hr />
            <div class="mb-4">
                As a DoE staff member, you can login to the Aurora College Schools Portal using your DoE email address and your DoE Portal password. Please note that you must be a staff member with a recognised Partner School with Aurora College for the login process to be successful.
            </div>

            @if (Model.Status == LoginModel.LoginStatus.InvalidUsername)
            {
                <span class="text-danger h4">Please check your email address and password and try again!</span>
            }

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                    <label asp-for="Input.Email" class="form-label"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.Password" class="form-control" autocomplete="password" aria-required="true" />
                    <label asp-for="Input.Password" class="form-label"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary" disabled>Login</button>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // When the form is submitted, mark the submit button disabled to prevent double-submission
        $(document).ready(function() {
            $('#account').on('submit',
                function(event) {
                    //console.log('submitted');
                    $('#login-submit').prop('disabled', true);
                });
        });

        // Remove disabled tag when page has finished loading
        $(document).ready(function() {
            $(':submit').prop('disabled', false);
        });
    </script>
}
